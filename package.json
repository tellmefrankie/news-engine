{
  "name": "news-engine",
  "version": "1.0.0",
  "description": "AI Tech News Analysis Engine - Collect, Analyze, Publish via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "run:now": "tsx src/index.ts --now",
    "monitor": "tsx src/monitor/index.ts",
    "monitor:once": "tsx src/monitor/index.ts --once",
    "market": "tsx src/market/index.ts",
    "market:portfolio": "tsx src/market/index.ts --portfolio",
    "options": "tsx src/options/index.ts",
    "options:sentiment": "tsx src/options/index.ts --sentiment",
    "card": "tsx src/instagram/index.ts",
    "card:sample": "tsx src/instagram/index.ts --sample",
    "growth": "tsx src/growth/index.ts",
    "growth:monitor": "tsx src/growth/index.ts --monitor-once",
    "growth:content": "tsx src/growth/index.ts --content",
    "dashboard": "tsx src/dashboard/server.ts",
    "finance": "tsx src/finance/index.ts",
    "finance:snapshot": "tsx src/finance/index.ts --snapshot",
    "finance:report": "tsx src/finance/index.ts --report",
    "thumbnails:png": "tsx src/growth/svg-to-png.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "news",
    "ai",
    "telegram",
    "claude",
    "rss"
  ],
  "author": "Jaehyun Park",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.41.1",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "playwright-core": "^1.58.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}